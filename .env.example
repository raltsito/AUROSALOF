# Base de datos - Railway Postgres
DATABASE_URL="postgresql://user:password@host:5432/railway"

# JWT - genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="reemplaza_con_secreto_aleatorio_de_64_bytes"
JWT_EXPIRES_IN="7d"

# Cifrado - genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="reemplaza_con_hex_de_64_caracteres"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_THEME="calm"

# Email SMTP (Hostinger)
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_USER="contacto@tudominio.com"
SMTP_PASS="password_del_buzon"
SMTP_FROM="ARUOSAL <contacto@tudominio.com>"
